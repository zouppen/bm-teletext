[Unit]
Description=BrandMeister Finnish Last Heard Collector
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=bm-teletext
WorkingDirectory=/opt/bm-teletext/bm-collector
Environment=DATABASE_URL=postgresql://bm_teletext:change-me@localhost:5432/bm_teletext
Environment=BM_LOG_LEVEL=INFO
Environment="BM_CONTEXT_ID_PATTERN=^244"
ExecStart=/opt/bm-teletext/bm-collector/.venv/bin/bm-collector
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
